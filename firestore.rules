rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Admin Check
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.is_admin == true;
    }

    // Helper: Auth Check
    function isAuthenticated() {
      return request.auth != null;
    }

    // 1. Markets: Public Read, Admin Write
    match /markets/{marketId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. Predictions: Public Read, Users can Create/Update their own
    match /predictions/{predictionId} {
      allow read: if true;
      
      // Allow creation if user is authenticated and sets strictly their own user_id
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      
      // Allow update if user owns the prediction (to change vote)
      allow update: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      
      // Allow deleting if admin (for cleanup) or owner (if we wanted retracting, but let's stick to admin/owner)
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
    }

    // 3. Profiles: Public Read, Owner Write (updates), Admin Write
    match /profiles/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow write: if isAdmin();
    }
  }
}
