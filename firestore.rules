rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Admin Check
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.is_admin == true;
    }

    // Helper: Auth Check
    function isAuthenticated() {
      return request.auth != null;
    }

    // 1. Markets: Public Read, Admin Write
    match /markets/{marketId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. Predictions: Public Read, auth users can create, but not edit (unless admin)
    match /predictions/{predictionId} {
      allow read: if true;
      // Allow creation if user is authenticated and sets strictly their own user_id
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      // Allow deleting if admin (for cleanup)
      allow delete: if isAdmin();
      // No updates allowed (avoids changing votes)
    }

    // 3. Profiles: Public Read, Owner Write (updates), Admin Write
    match /profiles/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow write: if isAdmin(); // Admin can prune/edit profiles if needed
    }
  }
}
